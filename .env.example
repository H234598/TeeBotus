TELEGRAM_BOT_INSTANCE=Bote_der_Wahrheit
# Optional: Kanaele explizit auswaehlen.
# Telegram-only ist der sichere Produktivstart, solange Signal/Matrix nicht voll konfiguriert sind.
# TEEBOTUS_CHANNELS=telegram
# TEEBOTUS_CHANNELS=telegram,signal
# TEEBOTUS_CHANNELS=telegram,matrix
# TEEBOTUS_CHANNELS=telegram,signal,matrix

TELEGRAM_BOT_TOKEN_BOTE_DER_WAHRHEIT=123456:replace-with-your-bote-der-wahrheit-token
TELEGRAM_BOT_TOKEN_DEPRESSIONSBOT=123456:replace-with-your-depressionsbot-token
# Optional fuer mehrere Depressionsbot-Botnamen:
# TELEGRAM_BOT_TOKENS_DEPRESSIONSBOT=123456:first-token,789012:second-token
# TELEGRAM_BOT_TOKEN_DEPRESSIONSBOT_2=789012:second-token
OPENAI_API_KEY_BOTE_DER_WAHRHEIT=sk-replace-with-your-bote-der-wahrheit-openai-api-key
OPENAI_API_KEY_DEPRESSIONSBOT=sk-replace-with-your-depressionsbot-openai-api-key
# Optional fuer mehrere Depressionsbot-Botnamen, passend zu den Telegram-Token-Slots:
# OPENAI_API_KEYS_DEPRESSIONSBOT=sk-first-openai-key,sk-second-openai-key
# OPENAI_API_KEY_DEPRESSIONSBOT_2=sk-second-openai-key
OPENAI_API_KEY=sk-optional-generic-fallback-openai-api-key

# Optional: Channel-spezifische OpenAI-Keys.
# Wenn nicht gesetzt, faellt TeeBotus auf OPENAI_API_KEY_<INSTANCE> oder OPENAI_API_KEY zurueck.
# OPENAI_API_KEY_DEPRESSIONSBOT_SIGNAL=sk-replace-with-signal-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_MATRIX=sk-replace-with-matrix-openai-api-key

# Optional: Signal ueber signal-cli-rest-api und signalbot.
# Beide Werte muessen pro Instanz zusammen gesetzt sein.
# Voraussetzung: signal-cli-rest-api laeuft erreichbar im json-rpc-Modus.
# SIGNAL_BOT_SERVICE_DEPRESSIONSBOT=http://127.0.0.1:8080
# SIGNAL_BOT_PHONE_NUMBER_DEPRESSIONSBOT=+491234567890
# SIGNAL_BOT_SERVICE_BOTE_DER_WAHRHEIT=http://127.0.0.1:8080
# SIGNAL_BOT_PHONE_NUMBER_BOTE_DER_WAHRHEIT=+491234567890
# Optional fuer mehrere Signal-Slots pro Instanz:
# SIGNAL_BOT_SERVICES_DEPRESSIONSBOT=http://127.0.0.1:8080,http://127.0.0.1:8081
# SIGNAL_BOT_PHONE_NUMBERS_DEPRESSIONSBOT=+491234567890,+499876543210

# Optional: Matrix ueber matrix-nio.
# Homeserver, User-ID und Access-Token muessen pro Instanz zusammen gesetzt sein.
# Matrix-Raeume gelten fuer Account-/Secret-Kommandos nur als privat, wenn genau zwei Mitglieder bekannt sind.
# MATRIX_BOT_HOMESERVER_DEPRESSIONSBOT=https://matrix.example.org
# MATRIX_BOT_USER_ID_DEPRESSIONSBOT=@teebotus:example.org
# MATRIX_BOT_ACCESS_TOKEN_DEPRESSIONSBOT=syt_replace_with_matrix_access_token
# MATRIX_BOT_DEVICE_ID_DEPRESSIONSBOT=TEEBOTUS
# Optional fuer mehrere Matrix-Slots pro Instanz:
# MATRIX_BOT_HOMESERVERS_DEPRESSIONSBOT=https://matrix-a.example.org,https://matrix-b.example.org
# MATRIX_BOT_USER_IDS_DEPRESSIONSBOT=@bot-a:example.org,@bot-b:example.org
# MATRIX_BOT_ACCESS_TOKENS_DEPRESSIONSBOT=syt_token_a,syt_token_b
# MATRIX_BOT_DEVICE_IDS_DEPRESSIONSBOT=TEEBOTUS_A,TEEBOTUS_B

# Optional fuer User-Memory-Schluessel:
# TELEGRAM_BOT_USER_MEMORY_KEY_BACKEND=keyring
# TELEGRAM_BOT_USER_MEMORY_KEY_BACKEND=passphrase
# TELEGRAM_BOT_USER_MEMORY_PASSPHRASE=...
# TELEGRAM_BOT_USER_MEMORY_PASSPHRASE_FILE=/absolute/path/to/passphrase.key
