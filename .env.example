TELEGRAM_BOT_INSTANCE=Bote_der_Wahrheit
# Optional: Kanaele explizit auswaehlen.
# Telegram-only ist der sichere Produktivstart, solange Signal/Matrix nicht voll konfiguriert sind.
# TEEBOTUS_CHANNELS=telegram
# TEEBOTUS_CHANNELS=telegram,signal
# TEEBOTUS_CHANNELS=telegram,matrix
# TEEBOTUS_CHANNELS=telegram,signal,matrix

TELEGRAM_BOT_TOKEN_BOTE_DER_WAHRHEIT=123456:replace-with-your-bote-der-wahrheit-token
TELEGRAM_BOT_TOKEN_DEPRESSIONSBOT=123456:replace-with-your-depressionsbot-token
# Optional: TeeBotus Logger/TBL. Beide Namen werden akzeptiert; der zweite
# entspricht dem Codex-History-Plan.
# TELEGRAM_BOT_TOKEN_TEEBOTUS_LOGGER=123456:replace-with-your-teebotus-logger-token
# TEEBOTUS_LOGGER_TELEGRAM_TOKEN=123456:replace-with-your-teebotus-logger-token
# Optional fuer mehrere Depressionsbot-Botnamen:
# TELEGRAM_BOT_TOKENS_DEPRESSIONSBOT=123456:first-token,789012:second-token
# TELEGRAM_BOT_TOKEN_DEPRESSIONSBOT_2=789012:second-token
OPENAI_API_KEY_BOTE_DER_WAHRHEIT=sk-replace-with-your-bote-der-wahrheit-openai-api-key
OPENAI_API_KEY_DEPRESSIONSBOT=sk-replace-with-your-depressionsbot-openai-api-key
# Optional fuer mehrere Depressionsbot-Botnamen, passend zu den Telegram-Token-Slots:
# OPENAI_API_KEYS_DEPRESSIONSBOT=sk-first-openai-key,sk-second-openai-key
# OPENAI_API_KEY_DEPRESSIONSBOT_2=sk-second-openai-key
OPENAI_API_KEY=sk-optional-generic-fallback-openai-api-key

# Optional: Channel-spezifische OpenAI-Keys.
# Wenn nicht gesetzt, faellt TeeBotus auf OPENAI_API_KEY_<INSTANCE> oder OPENAI_API_KEY zurueck.
# OPENAI_API_KEY_DEPRESSIONSBOT_SIGNAL=sk-replace-with-signal-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_MATRIX=sk-replace-with-matrix-openai-api-key

# Optional: instanzspezifische OpenAI-Keys fuer nicht-user-getriggerte Background-/Proactive-Aufrufe.
# Rollenkeys trennen Planung, Policy/Entscheidung und Worker.
# Fallback: Rolle -> INSTANCE_PROACTIVE(_SERVICES) -> PROACTIVE(_SERVICES)
# -> INSTANCE_BACKGROUND(_SERVICES) -> BACKGROUND(_SERVICES).
# Normale OPENAI_API_KEY_<INSTANCE>- oder OPENAI_API_KEY-Userantwort-Keys werden dafuer nicht genutzt.
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE_PLAN=sk-replace-with-proactive-plan-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE_PLAN_SERVICES=sk-replace-with-proactive-plan-services-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE_DECISION=sk-replace-with-proactive-decision-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE_DECISION_SERVICES=sk-replace-with-proactive-decision-services-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE_WORKER=sk-replace-with-proactive-worker-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE_WORKER_SERVICES=sk-replace-with-proactive-worker-services-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE=sk-replace-with-proactive-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_PROACTIVE_SERVICES=sk-replace-with-proactive-services-openai-api-key
# OPENAI_API_KEY_PROACTIVE=sk-replace-with-global-proactive-openai-api-key
# OPENAI_API_KEY_PROACTIVE_SERVICES=sk-replace-with-global-proactive-services-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_BACKGROUND=sk-replace-with-instance-background-openai-api-key
# OPENAI_API_KEY_DEPRESSIONSBOT_BACKGROUND_SERVICES=sk-replace-with-instance-background-services-openai-api-key
# OPENAI_API_KEY_BACKGROUND=sk-replace-with-global-background-openai-api-key
# OPENAI_API_KEY_BACKGROUND_SERVICES=sk-replace-with-global-background-services-openai-api-key
# Depressionsbot_BACKGROUND_SERVICES=sk-replace-with-background-services-openai-api-key

# Optional: neutrale Text-LLM-Profile ueber Provider-Profile.
# Beispiel: TEEBOTUS_LLM_PROFILE_DEPRESSIONSBOT=gemini_flash_stateful
# Beispiel: TEEBOTUS_LLM_PROFILE_DEPRESSIONSBOT=gemini_flash_stateless
# Beispiel 2.5 explizit: TEEBOTUS_LLM_PROFILE_DEPRESSIONSBOT=gemini_2_5_flash_stateful
# Beispiel: TEEBOTUS_LLM_PROFILE_DEPRESSIONSBOT=vertex_gemini_flash
# Beispiel: TEEBOTUS_LLM_PROFILE_DEPRESSIONSBOT_PROACTIVE_WORKER=gemini_flash_stateful
# Loglevel: critical, error, warning, info, debug, debug_all, finest.
# Numeric alias: 1 = debug_all.
# TEEBOTUS_LOG_LEVEL=info
# Lokales Ollama gezielt auslagern, z.B. fuer einen langsamen Logger-Bot.
# TEEBOTUS_LLM_OFFLOAD_LOCAL_OLLAMA_TEEBOTUS_LOGGER=1
# TEEBOTUS_LLM_OFFLOAD_LOCAL_OLLAMA_PROFILE_TEEBOTUS_LOGGER=openai_premium
# GEMINI_API_KEY=replace-with-your-gemini-api-key
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/vertex-service-account.json
# Optional: Gemini-Keyring fuer automatische Rotation bei 429/Quota/Limit.
# Google limitiert pro Projekt, nicht pro API-Key. Lege deshalb pro Projekt genau einen Key an.
# Reihenfolge ist spaltenweise ueber Accounts/Projektlisten:
# Account 1 Projekt 1, Account 2 Projekt 1, Account 3 Projekt 1, Account 1 Projekt 2, ...
# GEMINI_API_KEYS_ACCOUNT_1=replace-with-account-1-key-1,replace-with-account-1-key-2
# GEMINI_API_KEYS_ACCOUNT_2=replace-with-account-2-key-1,replace-with-account-2-key-2
# GEMINI_API_KEYS_ACCOUNT_3=replace-with-account-3-key-1,replace-with-account-3-key-2
# Instanzspezifisch:
# TEEBOTUS_GEMINI_API_KEYS_DEPRESSIONSBOT_ACCOUNT_1=replace-with-key-a,replace-with-key-b
# Rollenspezifisch:
# TEEBOTUS_GEMINI_API_KEYS_DEPRESSIONSBOT_PROACTIVE_WORKER_ACCOUNT_1=replace-with-worker-key-a,replace-with-worker-key-b
# Optional: lokale Free-Tier-Budgets pro Projekt-Key. Werte in AI Studio/Projektquoten pruefen.
# Der Guard bricht vor dem Request ab, wenn RPM/TPM/RPD plus Tokenreserve ueberschritten wuerden.
# TEEBOTUS_GEMINI_FREE_TIER_RPM=5
# TEEBOTUS_GEMINI_FREE_TIER_TPM=250000
# TEEBOTUS_GEMINI_FREE_TIER_RPD=20
# TEEBOTUS_GEMINI_FREE_TIER_RESERVE_TOKENS=2048
# Optional: einmal taeglich aktuelle Free-Tier-Limits abrufen und cachen.
# Die Default-Quelle ist die offizielle Gemini-Rate-Limit-Seite; fuer echte
# projektaktive AI-Studio-Quoten kann hier auch ein eigener JSON-Export stehen.
# TEEBOTUS_GEMINI_FREE_TIER_REFRESH_ENABLED=true
# TEEBOTUS_GEMINI_FREE_TIER_REFRESH_INTERVAL_SECONDS=86400
# TEEBOTUS_GEMINI_FREE_TIER_LIMITS_URL=https://ai.google.dev/gemini-api/docs/rate-limits
# TEEBOTUS_GEMINI_FREE_TIER_CACHE=/home/teladi/.cache/teebotus/gemini_free_tier_limits.json
# Instanzspezifisch:
# TEEBOTUS_GEMINI_FREE_TIER_DEPRESSIONSBOT_TPM=250000

# Optional: Signal ueber signal-cli-rest-api und signalbot.
# Beide Werte muessen pro Instanz zusammen gesetzt sein.
# Voraussetzung: signal-cli-rest-api laeuft erreichbar im json-rpc-Modus.
# SIGNAL_BOT_SERVICE_DEPRESSIONSBOT=http://127.0.0.1:8080
# SIGNAL_BOT_PHONE_NUMBER_DEPRESSIONSBOT=+491234567890
# SIGNAL_BOT_SERVICE_BOTE_DER_WAHRHEIT=http://127.0.0.1:8080
# SIGNAL_BOT_PHONE_NUMBER_BOTE_DER_WAHRHEIT=+491234567890
# Optional fuer mehrere Signal-Slots pro Instanz:
# SIGNAL_BOT_SERVICES_DEPRESSIONSBOT=http://127.0.0.1:8080,http://127.0.0.1:8081
# SIGNAL_BOT_PHONE_NUMBERS_DEPRESSIONSBOT=+491234567890,+499876543210
# Alternativ nummeriert:
# SIGNAL_BOT_SERVICE_DEPRESSIONSBOT_2=http://127.0.0.1:8081
# SIGNAL_BOT_PHONE_NUMBER_DEPRESSIONSBOT_2=+499876543210

# Optional: Matrix ueber matrix-nio.
# Homeserver, User-ID und Access-Token muessen pro Instanz zusammen gesetzt sein.
# Matrix-Raeume gelten fuer Account-/Secret-Kommandos nur als privat, wenn genau zwei Mitglieder bekannt sind.
# MATRIX_BOT_HOMESERVER_DEPRESSIONSBOT=https://matrix.example.org
# MATRIX_BOT_USER_ID_DEPRESSIONSBOT=@teebotus:example.org
# MATRIX_BOT_ACCESS_TOKEN_DEPRESSIONSBOT=syt_replace_with_matrix_access_token
# MATRIX_BOT_DEVICE_ID_DEPRESSIONSBOT=TEEBOTUS
# Optional fuer mehrere Matrix-Slots pro Instanz:
# MATRIX_BOT_HOMESERVERS_DEPRESSIONSBOT=https://matrix-a.example.org,https://matrix-b.example.org
# MATRIX_BOT_USER_IDS_DEPRESSIONSBOT=@bot-a:example.org,@bot-b:example.org
# MATRIX_BOT_ACCESS_TOKENS_DEPRESSIONSBOT=syt_token_a,syt_token_b
# MATRIX_BOT_DEVICE_IDS_DEPRESSIONSBOT=TEEBOTUS_A,TEEBOTUS_B
# Alternativ nummeriert:
# MATRIX_BOT_HOMESERVER_DEPRESSIONSBOT_2=https://matrix-b.example.org
# MATRIX_BOT_USER_ID_DEPRESSIONSBOT_2=@bot-b:example.org
# MATRIX_BOT_ACCESS_TOKEN_DEPRESSIONSBOT_2=syt_token_b
# MATRIX_BOT_DEVICE_ID_DEPRESSIONSBOT_2=TEEBOTUS_B

# Proactive Agent ist pro Instanz default-off.
# TEEBOTUS_PROACTIVE_AGENT_INSTANCES=Depressionsbot
# User-local timezone used by proactive windows, activity profiles, and
# notification wake windows.  Stored timestamps remain offset-aware/UTC.
# TEEBOTUS_TIMEZONE=Europe/Berlin
# LLM-/Tool-Planer ist ein separater Gate und braucht einen OpenAI-Key fuer die Instanz.
# TEEBOTUS_PROACTIVE_LLM_PLANNER_INSTANCES=Depressionsbot

# Admin-Account-Gruppe fuer Runtime-Warnungen. Ohne Override nutzt TeeBotus die
# fest konfigurierte lokale Admin-Gruppe. Instanzspezifische Werte ersetzen den
# globalen Wert. Werte sind Account-IDs, keine Telegram-/Signal-/Matrix-IDs.
# TEEBOTUS_ADMIN_ACCOUNT_IDS=account_id_a,account_id_b
# TEEBOTUS_ADMIN_ACCOUNT_IDS_DEPRESSIONSBOT=account_id_a

# Optionaler Ausgangspfad für berichte/tests/md/json/texte usw.
# Standard ist bei dir: /home/teladi/Dokumente/Obsidian_Vaults/Teladi_Programming/incomming
# Kann hier zentral pro Deployment ueberschrieben werden.
# TEEBOTUS_OBSIDIAN_INCOMING_DIR=/home/user/path/to/obsidian/incoming

# Optional fuer User-Memory-Schluessel:
# TELEGRAM_BOT_USER_MEMORY_KEY_BACKEND=keyring
# TELEGRAM_BOT_USER_MEMORY_KEY_BACKEND=passphrase
# TELEGRAM_BOT_USER_MEMORY_PASSPHRASE=...
# TELEGRAM_BOT_USER_MEMORY_PASSPHRASE_FILE=/absolute/path/to/passphrase.key

# Optional: strukturierten Account-Memory in PostgreSQL statt JSONL/JSON speichern.
# Payloads bleiben pro Eintrag verschluesselt; querybar sind nur Ranking-/Keyword-Metadaten.
# TEEBOTUS_ACCOUNT_MEMORY_BACKEND=sqlite
# TEEBOTUS_ACCOUNT_MEMORY_SQLITE_PATH=/path/to/Account_Memory.sqlite3
# TEEBOTUS_ACCOUNT_MEMORY_SQLITE_FALLBACK_PATH=/path/to/Account_Memory.backup.sqlite3
# TEEBOTUS_ACCOUNT_MEMORY_BACKEND=postgres
# TEEBOTUS_ACCOUNT_MEMORY_POSTGRES_DSN=postgresql://teebotus:password@127.0.0.1:5432/teebotus
# TEEBOTUS_ACCOUNT_MEMORY_POSTGRES_CONNECT_TIMEOUT=5

# Optional: maximale Retries bei strukturierter Entscheidungs-Ausgabe (Pydantic-AI).
# Standardwert: 2.
# TEEBOTUS_STRUCTURED_DECISION_MAX_OUTPUT_RETRIES=2
# Optional: Text-LLM/Structured-Decision und lokaler-Ollama-Offload pro Instanz.
# TEEBOTUS_LLM_PROFILE_TEEBOTUS_LOGGER=gemini_flash_stateful
# TEEBOTUS_STRUCTURED_DECISION_ENABLED_TEEBOTUS_LOGGER=0
# TEEBOTUS_LLM_OFFLOAD_LOCAL_OLLAMA_TEEBOTUS_LOGGER=1
# TEEBOTUS_LLM_OFFLOAD_LOCAL_OLLAMA_PROFILE_TEEBOTUS_LOGGER=gemini_flash_stateful
