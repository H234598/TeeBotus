TELEGRAM_BOT_INSTANCE=Bote_der_Wahrheit
TELEGRAM_BOT_TOKEN_BOTE_DER_WAHRHEIT=123456:replace-with-your-bote-der-wahrheit-token
TELEGRAM_BOT_TOKEN_DEPRESSIONSBOT=123456:replace-with-your-depressionsbot-token
# Optional fuer mehrere Depressionsbot-Botnamen:
# TELEGRAM_BOT_TOKENS_DEPRESSIONSBOT=123456:first-token,789012:second-token
# TELEGRAM_BOT_TOKEN_DEPRESSIONSBOT_2=789012:second-token
OPENAI_API_KEY_BOTE_DER_WAHRHEIT=sk-replace-with-your-bote-der-wahrheit-openai-api-key
OPENAI_API_KEY_DEPRESSIONSBOT=sk-replace-with-your-depressionsbot-openai-api-key
# Optional fuer mehrere Depressionsbot-Botnamen, passend zu den Telegram-Token-Slots:
# OPENAI_API_KEYS_DEPRESSIONSBOT=sk-first-openai-key,sk-second-openai-key
# OPENAI_API_KEY_DEPRESSIONSBOT_2=sk-second-openai-key
OPENAI_API_KEY=sk-optional-generic-fallback-openai-api-key

# Optional fuer User-Memory-Schluessel:
# TELEGRAM_BOT_USER_MEMORY_KEY_BACKEND=keyring
# TELEGRAM_BOT_USER_MEMORY_KEY_BACKEND=passphrase
# TELEGRAM_BOT_USER_MEMORY_PASSPHRASE=...
# TELEGRAM_BOT_USER_MEMORY_PASSPHRASE_FILE=/absolute/path/to/passphrase.key
