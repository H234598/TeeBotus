{
  "layout": {
    "type": "layout",
    "pages": [
      "main-page",
      "actions-page",
      "about-page"
    ],
    "main-page": {
      "type": "page",
      "title": "TB",
      "sections": [
        "settings-logo-header-section",
        "menu-map-section",
        "runtime-section",
        "display-section",
        "sections-section",
        "history-dispatcher-section"
      ]
    },
    "actions-page": {
      "type": "page",
      "title": "Actions",
      "sections": [
        "service-actions-section",
        "tools-section",
        "links-section"
      ]
    },
    "about-page": {
      "type": "page",
      "title": "About",
      "sections": [
        "about-section"
      ]
    },
    "settings-logo-header-section": {
      "type": "section",
      "title": "",
      "keys": [
        "settings-logo-header"
      ]
    },
    "menu-map-section": {
      "type": "section",
      "title": "Main menu map",
      "keys": [
        "main-menu-map"
      ]
    },
    "runtime-section": {
      "type": "section",
      "title": "Runtime status",
      "keys": [
        "repo-path",
        "python-command",
        "channels",
        "runtime-unit",
        "qdrant-unit",
        "qdrant-url",
        "default-instance",
        "status-refresh-seconds",
        "status-timeout-seconds"
      ]
    },
    "display-section": {
      "type": "section",
      "title": "Panel display",
      "keys": [
        "show-panel-label",
        "panel-label-mode",
        "auto-refresh"
      ]
    },
    "sections-section": {
      "type": "section",
      "title": "Visible menu sections",
      "keys": [
        "show-messenger-section",
        "show-llm-section",
        "show-api-section",
        "show-memory-section",
        "show-bibliothekar-section",
        "show-proactive-section",
        "show-actions-section",
        "show-quick-commands-section",
        "show-project-section"
      ]
    },
    "history-dispatcher-section": {
      "type": "section",
      "title": "History-Dispatcher mirror",
      "keys": [
        "show-history-dispatcher-section",
        "history-dispatcher-runtime-path",
        "history-dispatcher-command-path",
        "history-dispatcher-config-path",
        "history-dispatcher-collector-enabled",
        "history-dispatcher-collector-interval-seconds",
        "history-dispatcher-collector-scan-limit",
        "history-dispatcher-log-level",
        "history-dispatcher-status-heartbeat-seconds",
        "history-dispatcher-dispatch-enabled",
        "history-dispatcher-dispatch-paused",
        "history-dispatcher-dispatch-batch-size",
        "history-dispatcher-claim-ttl-seconds",
        "history-dispatcher-max-attempts",
        "history-dispatcher-completed-retention-days",
        "history-dispatcher-audit-retention-days"
      ]
    },
    "service-actions-section": {
      "type": "section",
      "title": "Bot service actions",
      "keys": [
        "enable-service-actions",
        "confirm-service-actions",
        "terminal-command"
      ]
    },
    "tools-section": {
      "type": "section",
      "title": "Tool actions",
      "keys": [
        "bibliothekar-instance",
        "library-path",
        "proactive-instance",
        "proactive-command",
        "codex-usage-path",
        "codex-usage-command"
      ]
    },
    "links-section": {
      "type": "section",
      "title": "Project links",
      "keys": [
        "github-url",
        "commits-url"
      ]
    },
    "about-section": {
      "type": "section",
      "title": "TeeBotus Applet",
      "keys": [
        "about-logo",
        "about-text"
      ]
    }
  },
  "main-menu-map": {
    "type": "label",
    "description": "The panel menu shows a compact runtime card first, then optional sections for Messenger, LLM routes, API keys and usage, memory, Bibliothekar, proactive agent, bot service actions, quick chat commands, and project links. Runtime status is read through the fixed TeeBotus helper command; service actions call the configured user-systemd unit."
  },
  "settings-logo-header": {
    "type": "custom",
    "file": "SettingsLogo.py",
    "widget": "HeaderLogo",
    "description": "TeeBotus settings header logo",
    "default": ""
  },
  "repo-path": {
    "type": "entry",
    "description": "TeeBotus repository path",
    "tooltip": "Used as working directory for python -m TeeBotus and git status.",
    "default": "/home/teladi/TeeBotus"
  },
  "python-command": {
    "type": "entry",
    "description": "Python executable",
    "tooltip": "Use the same local Python environment as teebotus.service unless you have a specific reason to override it.",
    "default": "/home/teladi/TeeBotus/.venv-py313/bin/python"
  },
  "channels": {
    "type": "combobox",
    "description": "Runtime-status channels",
    "options": {
      "Telegram + Signal": "telegram,signal",
      "Telegram + Signal + Matrix": "telegram,signal,matrix",
      "Telegram only": "telegram",
      "Signal only": "signal",
      "Matrix only": "matrix"
    },
    "default": "telegram,signal"
  },
  "runtime-unit": {
    "type": "entry",
    "description": "User-systemd bot unit",
    "default": "teebotus.service"
  },
  "qdrant-unit": {
    "type": "entry",
    "description": "User-systemd Qdrant unit",
    "tooltip": "Used for Qdrant status actions and service diagnostics in the memory menu.",
    "default": "teebotus-qdrant.service"
  },
  "qdrant-url": {
    "type": "entry",
    "description": "Local Qdrant URL",
    "tooltip": "Must stay local. Used for vector counts and Qdrant collection actions.",
    "default": "http://127.0.0.1:6333"
  },
  "default-instance": {
    "type": "entry",
    "description": "Default instance for helper actions",
    "default": "Depressionsbot"
  },
  "status-refresh-seconds": {
    "type": "spinbutton",
    "description": "Automatic refresh interval in seconds",
    "min": 15,
    "max": 3600,
    "step": 5,
    "default": 60
  },
  "status-timeout-seconds": {
    "type": "spinbutton",
    "description": "Status command timeout in seconds",
    "min": 5,
    "max": 120,
    "step": 5,
    "default": 30
  },
  "show-panel-label": {
    "type": "switch",
    "description": "Panel text is fixed to TB",
    "default": true
  },
  "panel-label-mode": {
    "type": "combobox",
    "description": "Legacy panel mode (panel still shows TB)",
    "options": {
      "Short health": "health",
      "Instance count": "instances",
      "Version": "version",
      "Icon only": "icon"
    },
    "default": "health"
  },
  "auto-refresh": {
    "type": "switch",
    "description": "Refresh status automatically",
    "default": true
  },
  "show-messenger-section": {
    "type": "switch",
    "description": "Show Messenger section",
    "default": true
  },
  "show-llm-section": {
    "type": "switch",
    "description": "Show LLM and provider section",
    "default": true
  },
  "show-api-section": {
    "type": "switch",
    "description": "Show API keys and usage section",
    "default": true
  },
  "show-memory-section": {
    "type": "switch",
    "description": "Show memory and storage section",
    "default": true
  },
  "show-bibliothekar-section": {
    "type": "switch",
    "description": "Show Bibliothekar section",
    "default": true
  },
  "show-proactive-section": {
    "type": "switch",
    "description": "Show proactive agent section",
    "default": true
  },
  "show-actions-section": {
    "type": "switch",
    "description": "Show bot service actions",
    "default": true
  },
  "show-quick-commands-section": {
    "type": "switch",
    "description": "Show quick chat commands",
    "default": true
  },
  "show-project-section": {
    "type": "switch",
    "description": "Show project links",
    "default": true
  },
  "show-history-dispatcher-section": {
    "type": "switch",
    "description": "Show the full History-Dispatcher mirror",
    "tooltip": "Reads the bounded local Dispatcher status snapshot and exposes only allowlisted actions.",
    "default": false
  },
  "history-dispatcher-runtime-path": {
    "type": "entry",
    "description": "History-Dispatcher runtime directory",
    "default": "/run/user/1000/history-dispatcher"
  },
  "history-dispatcher-command-path": {
    "type": "entry",
    "description": "History-Dispatcher executable",
    "default": "/home/teladi/History-Dispatcher/.venv-py313/bin/history-dispatcher"
  },
  "history-dispatcher-config-path": {
    "type": "entry",
    "description": "History-Dispatcher config.toml",
    "default": "/home/teladi/.config/history-dispatcher/config.toml"
  },
  "history-dispatcher-collector-enabled": {
    "type": "switch",
    "description": "Enable History-Dispatcher collector",
    "default": true
  },
  "history-dispatcher-collector-interval-seconds": {
    "type": "spinbutton",
    "description": "Dispatcher collector interval in seconds",
    "min": 60,
    "max": 86400,
    "step": 60,
    "default": 300
  },
  "history-dispatcher-collector-scan-limit": {
    "type": "spinbutton",
    "description": "Dispatcher source file scan limit",
    "min": 1,
    "max": 10000,
    "step": 1,
    "default": 25
  },
  "history-dispatcher-log-level": {
    "type": "combobox",
    "description": "Dispatcher log level",
    "options": {"Debug": "DEBUG", "Info": "INFO", "Warning": "WARNING", "Error": "ERROR", "Critical": "CRITICAL"},
    "default": "INFO"
  },
  "history-dispatcher-status-heartbeat-seconds": {
    "type": "spinbutton",
    "description": "Dispatcher status heartbeat in seconds",
    "min": 1,
    "max": 3600,
    "step": 1,
    "default": 30
  },
  "history-dispatcher-dispatch-enabled": {
    "type": "switch",
    "description": "Enable Dispatcher dispatch",
    "default": true
  },
  "history-dispatcher-dispatch-paused": {
    "type": "switch",
    "description": "Pause History-Dispatcher dispatch",
    "default": false
  },
  "history-dispatcher-dispatch-batch-size": {
    "type": "spinbutton",
    "description": "Dispatcher dispatch batch size",
    "min": 1,
    "max": 1000,
    "step": 1,
    "default": 20
  },
  "history-dispatcher-claim-ttl-seconds": {
    "type": "spinbutton",
    "description": "Dispatcher claim lease in seconds",
    "min": 1,
    "max": 604800,
    "step": 1,
    "default": 900
  },
  "history-dispatcher-max-attempts": {
    "type": "spinbutton",
    "description": "Dispatcher maximum automatic attempts",
    "min": 1,
    "max": 1000,
    "step": 1,
    "default": 12
  },
  "history-dispatcher-completed-retention-days": {
    "type": "spinbutton",
    "description": "Completed Dispatcher retention in days",
    "min": 1,
    "max": 3650,
    "step": 1,
    "default": 30
  },
  "history-dispatcher-audit-retention-days": {
    "type": "spinbutton",
    "description": "Dispatcher audit retention in days",
    "min": 1,
    "max": 3650,
    "step": 1,
    "default": 365
  },
  "enable-service-actions": {
    "type": "switch",
    "description": "Enable start/restart/stop menu items",
    "tooltip": "The menu items call systemctl --user for the configured unit. Disable this if the applet should be read-only.",
    "default": true
  },
  "confirm-service-actions": {
    "type": "switch",
    "description": "Ask before start/restart/stop",
    "tooltip": "Uses a native Cinnamon confirmation dialog. If the dialog cannot be opened, the action is blocked instead of running silently.",
    "default": true
  },
  "terminal-command": {
    "type": "entry",
    "description": "Preferred terminal command",
    "tooltip": "Leave empty for auto-detection among gnome-terminal, x-terminal-emulator, kgx, konsole, and xterm. Arguments are allowed; xterm and konsole use -e, other terminals use -- unless already specified.",
    "default": ""
  },
  "bibliothekar-instance": {
    "type": "entry",
    "description": "Bibliothekar instance",
    "default": "Depressionsbot"
  },
  "library-path": {
    "type": "entry",
    "description": "Library folder",
    "default": "/home/teladi/TeeBotus/instances/Depressionsbot/data/Bibliothek"
  },
  "proactive-instance": {
    "type": "entry",
    "description": "Proactive-agent instance",
    "default": "Depressionsbot"
  },
  "proactive-command": {
    "type": "entry",
    "description": "Manual proactive command",
    "default": "/usr/bin/python3 -m TeeBotus.proactive --instance Depressionsbot --dispatch --plan --tool-plan"
  },
  "codex-usage-path": {
    "type": "entry",
    "description": "codex-usage repository path",
    "tooltip": "Used by API usage menu actions. The runtime status also reads local codex-usage snapshots when present.",
    "default": "/home/teladi/codex-usage"
  },
  "codex-usage-command": {
    "type": "entry",
    "description": "codex-usage command",
    "tooltip": "Command used for codex-usage terminal actions; leave as codex-usage when it is installed in ~/.local/bin or a trusted system bin directory.",
    "default": "codex-usage"
  },
  "github-url": {
    "type": "entry",
    "description": "GitHub repository URL",
    "default": "https://github.com/H234598/TeeBotus"
  },
  "commits-url": {
    "type": "entry",
    "description": "Commit history URL",
    "default": "https://github.com/H234598/TeeBotus/commits/main"
  },
  "about-logo": {
    "type": "custom",
    "file": "SettingsLogo.py",
    "widget": "AboutLogo",
    "description": "TeeBotus about logo",
    "default": ""
  },
  "about-text": {
    "type": "label",
    "description": "TeeBotus Cinnamon applet\\nPanel diagnostics, bot runtime controls, quick chat commands, Bibliothekar and proactive-agent launchers."
  }
}
